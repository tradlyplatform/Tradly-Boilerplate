# ─── Tradly Workspace ─────────────────────────────────────────────────────────
# Your Tradly workspace domain (e.g. beauty.tradly.co)
VITE_TRADLY_DOMAIN=your-workspace.tradly.co

# Public key for your workspace — get this from your Tradly dashboard
VITE_TRADLY_PK_KEY=your-public-key
# Optional compatibility alias used by some launcher deployments
VITE_TRADLY_PUBLISHABLE_KEY=your-public-key

# Optional API base override. Defaults to the public Tradly API.
VITE_TRADLY_BASE_URL=https://api.tradly.app

# Deployment environment: production | development | sandbox
VITE_TRADLY_ENV=production

# ─── Defaults ─────────────────────────────────────────────────────────────────
# Hardcoded fallback currency and language.
# These can be swapped at runtime via state/app/slice (setCurrency / setLanguage).
VITE_DEFAULT_CURRENCY=USD
VITE_DEFAULT_LANGUAGE=en
